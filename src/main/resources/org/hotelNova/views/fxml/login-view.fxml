<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.hotelNova.views.controllers.LoginController"
      stylesheets="@../styles/main.css"
      alignment="CENTER" spacing="30" styleClass="main-container">
    
    <VBox styleClass="card" spacing="25" alignment="CENTER" maxWidth="400">
        <padding>
            <Insets top="40" right="40" bottom="40" left="40"/>
        </padding>
        
        <VBox spacing="10" alignment="CENTER">
            <Label text="Hotel Nova" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
            <Label text="Hotel Operations Platform" style="-fx-font-size: 14; -fx-text-fill: #7f8c8d;"/>
        </VBox>
        
        <VBox spacing="20" maxWidth="300">
            <VBox spacing="8">
                <Label text="Username" styleClass="form-label"/>
                <TextField fx:id="usernameField" promptText="Enter your username"/>
            </VBox>
            
            <VBox spacing="8">
                <Label text="Password" styleClass="form-label"/>
                <PasswordField fx:id="passwordField" promptText="Enter your password"/>
            </VBox>
            
            <Label fx:id="errorLabel" styleClass="message-error" visible="false" managed="false" 
                   text="Invalid username or password." wrapText="true"/>
        </VBox>
        
        <VBox spacing="15" alignment="CENTER" maxWidth="300">
            <Button text="Sign In" styleClass="button-primary" maxWidth="300"
                    onAction="#handleLogin"/>
            <Button text="Exit" styleClass="button-secondary" maxWidth="300"
                    onAction="#handleExit"/>
        </VBox>
        
        <VBox spacing="10" alignment="CENTER">
            <Label text="Need a staff account?" style="-fx-text-fill: #7f8c8d;"/>
            <Button text="Register" styleClass="button-secondary" onAction="#handleGoToRegister"/>
        </VBox>
    </VBox>
    
</VBox>
