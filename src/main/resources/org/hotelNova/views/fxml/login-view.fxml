<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.hotelNova.views.controllers.LoginController"
      stylesheets="@../styles/main.css"
      alignment="CENTER" spacing="30" styleClass="main-container">
    
    <!-- Login Card -->
    <VBox styleClass="card" spacing="25" alignment="CENTER" maxWidth="400">
        <padding>
            <Insets top="40" right="40" bottom="40" left="40"/>
        </padding>
        
        <!-- Header -->
        <VBox spacing="10" alignment="CENTER">
            <Label text="Hotel Nova" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
            <Label text="Sistema de Gestión Hotelera" style="-fx-font-size: 14; -fx-text-fill: #7f8c8d;"/>
        </VBox>
        
        <!-- Form -->
        <VBox spacing="20" maxWidth="300">
            <VBox spacing="8">
                <Label text="Usuario" styleClass="form-label"/>
                <TextField fx:id="usernameField" promptText="Ingrese su usuario"/>
            </VBox>
            
            <VBox spacing="8">
                <Label text="Contraseña" styleClass="form-label"/>
                <PasswordField fx:id="passwordField" promptText="Ingrese su contraseña"/>
            </VBox>
            
            <!-- Error Message -->
            <Label fx:id="errorLabel" styleClass="message-error" visible="false" managed="false" 
                   text="Usuario o contraseña incorrectos" wrapText="true"/>
        </VBox>
        
        <!-- Actions -->
        <VBox spacing="15" alignment="CENTER" maxWidth="300">
            <Button text="Iniciar Sesión" styleClass="button-primary" maxWidth="300"
                    onAction="#handleLogin"/>
            <Button text="Salir" styleClass="button-secondary" maxWidth="300"
                    onAction="#handleExit"/>
        </VBox>
        
        <!-- Register Link -->
        <VBox spacing="10" alignment="CENTER">
            <Label text="¿No tienes una cuenta?" style="-fx-text-fill: #7f8c8d;"/>
            <Button text="Registrarse" styleClass="button-secondary" onAction="#handleGoToRegister"/>
        </VBox>
    </VBox>
    
</VBox>
