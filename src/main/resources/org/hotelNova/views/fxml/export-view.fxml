<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.hotelNova.views.controllers.ExportController"
      stylesheets="@../styles/main.css"
      spacing="30" styleClass="main-container" alignment="TOP_CENTER">
    
    <VBox spacing="6" alignment="TOP_CENTER">
        <Label text="Data Exports" styleClass="page-title"/>
        <Label fx:id="sectionDescriptionLabel" text="Generate CSV snapshots for guests, rooms, and bookings." styleClass="page-subtitle"/>
    </VBox>
    
    <VBox styleClass="form-container" spacing="25" maxWidth="500">
        <Label text="Select the datasets you want to export:" styleClass="section-title"/>
        
        <VBox spacing="15">
            <CheckBox fx:id="exportGuestsCheckBox" text="Guests" selected="true"/>
            <CheckBox fx:id="exportRoomsCheckBox" text="Rooms" selected="true"/>
            <CheckBox fx:id="exportBookingsCheckBox" text="Bookings" selected="true"/>
        </VBox>
        
        <VBox spacing="8">
            <Label text="Export Directory" styleClass="form-label"/>
            <HBox spacing="10">
                <TextField fx:id="pathField" text="exports/" editable="false" HBox.hgrow="ALWAYS"/>
                <Button text="Browse" styleClass="button-secondary" onAction="#handleBrowsePath"/>
            </HBox>
        </VBox>
        
        <HBox spacing="15" alignment="CENTER">
            <Button text="Export Data" styleClass="button-primary" onAction="#handleExport"/>
            <Button text="Reset" styleClass="button-secondary" onAction="#handleClear"/>
        </HBox>
        
        <Label fx:id="exportErrorLabel" styleClass="message-error" visible="false" managed="false" wrapText="true"/>
        <Label fx:id="exportSuccessLabel" styleClass="message-success" visible="false" managed="false" wrapText="true"/>
    </VBox>
    
    <VBox fx:id="resultsContainer" styleClass="card" spacing="15" visible="false" managed="false" maxWidth="600">
        <Label text="Export Results" styleClass="section-title"/>
        
        <TableView fx:id="resultsTable" prefHeight="200">
            <columns>
                <TableColumn fx:id="entityColumn" text="Dataset" prefWidth="150"/>
                <TableColumn fx:id="recordsColumn" text="Records" prefWidth="100"/>
                <TableColumn fx:id="fileColumn" text="File" prefWidth="200"/>
                <TableColumn fx:id="statusColumn" text="Status" prefWidth="100"/>
            </columns>
        </TableView>
        
        <Button text="Open Directory" styleClass="button-secondary" onAction="#handleOpenDirectory"/>
    </VBox>
    
</VBox>
