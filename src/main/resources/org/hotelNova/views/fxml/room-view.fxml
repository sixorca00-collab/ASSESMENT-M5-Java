<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.hotelNova.views.controllers.RoomController"
      stylesheets="@../styles/main.css"
      spacing="20" styleClass="main-container">
    
    <HBox alignment="CENTER_LEFT" spacing="15">
        <VBox spacing="6">
            <Label text="Room Inventory" styleClass="page-title"/>
            <Label fx:id="sectionDescriptionLabel" text="Track room types, pricing, and availability." styleClass="page-subtitle"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="addRoomButton" text="Add Room" styleClass="button-primary" onAction="#showAddRoomForm"/>
    </HBox>

    <Label fx:id="modeInfoLabel" styleClass="message-warning" visible="false" managed="false" wrapText="true"/>
    
    <VBox fx:id="roomFormContainer" styleClass="form-container" spacing="20" visible="false" managed="false">
        <Label fx:id="formTitleLabel" text="Add Room" styleClass="section-title"/>
        
        <GridPane hgap="20" vgap="15">
            <Label text="Room Number" GridPane.rowIndex="0" GridPane.columnIndex="0" styleClass="form-label"/>
            <TextField fx:id="numberField" GridPane.rowIndex="0" GridPane.columnIndex="1" maxWidth="150"/>
            
            <Label text="Room Type" GridPane.rowIndex="1" GridPane.columnIndex="0" styleClass="form-label"/>
            <ComboBox fx:id="typeComboBox" GridPane.rowIndex="1" GridPane.columnIndex="1" maxWidth="200"/>
            
            <Label text="Nightly Rate" GridPane.rowIndex="2" GridPane.columnIndex="0" styleClass="form-label"/>
            <TextField fx:id="priceField" GridPane.rowIndex="2" GridPane.columnIndex="1" maxWidth="150"/>
        </GridPane>
        
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Button text="Save" styleClass="button-primary" onAction="#handleSaveRoom"/>
            <Button text="Cancel" styleClass="button-secondary" onAction="#hideRoomForm"/>
        </HBox>
        
        <Label fx:id="roomErrorLabel" styleClass="message-error" visible="false" managed="false"/>
        <Label fx:id="roomSuccessLabel" styleClass="message-success" visible="false" managed="false"/>
    </VBox>
    
    <HBox spacing="15" alignment="CENTER_LEFT">
        <ComboBox fx:id="filterTypeComboBox" promptText="Filter by type" maxWidth="150"/>
        <ComboBox fx:id="filterStatusComboBox" promptText="Filter by status" maxWidth="150"/>
        <Button text="Apply" styleClass="button-secondary" onAction="#handleFilter"/>
        <Button text="Clear" styleClass="button-secondary" onAction="#handleClearFilter"/>
    </HBox>
    
    <TableView fx:id="roomsTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="roomIdColumn" text="ID" prefWidth="50"/>
            <TableColumn fx:id="roomNumberColumn" text="Number" prefWidth="100"/>
            <TableColumn fx:id="roomTypeColumn" text="Type" prefWidth="120"/>
            <TableColumn fx:id="roomPriceColumn" text="Rate" prefWidth="100"/>
            <TableColumn fx:id="roomAvailableColumn" text="Available" prefWidth="100"/>
            <TableColumn fx:id="roomActionsColumn" text="Actions" prefWidth="150"/>
        </columns>
    </TableView>
    
</VBox>
